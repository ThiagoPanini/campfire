{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Campfire",
  "description": "Private music hub for small circles — track what you know, see what you are learning, share with the room.",
  "colors": {
    "primary": "#E8813A",
    "light": "#FFFFFF",
    "dark": "#131313"
  },
  "appearance": {
    "default": "dark",
    "strict": false
  },
  "background": {
    "color": {
      "dark": "#131313",
      "light": "#F5F5F5"
    }
  },
  "styling": {
    "eyebrows": "section"
  },
  "contextual": {
    "options": [
      "copy",
      "view"
    ]
  },
  "navbar": {
    "title": "campfire",
    "primary": {
      "href": "https://github.com/ThiagoPanini/campfire",
      "type": "github"
    }
  },
  "footer": {
    "socials": {
      "github": "https://github.com/ThiagoPanini/campfire",
      "website": "https://thiagopanini.dev/"
    }
  },
  "fonts": {
    "heading": {
      "family": "Anton",
      "weight": 400
    },
    "body": {
      "family": "Space Grotesk",
      "weight": 300
    }
  },
  "icons": {
    "library": "lucide"
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Docs",
        "icon": "flame",
        "groups": [
          {
            "group": "INTRODUCTION",
            "pages": [
              "get-started/introduction/overview",
              "get-started/introduction/current-status",
              "get-started/introduction/quickstart",
              "get-started/introduction/recent-implementations",
              "get-started/introduction/roadmap"
            ]
          },
          {
            "group": "ARCHITECTURE",
            "pages": [
              "get-started/architecture/overview",
              "get-started/architecture/frontend",
              "get-started/architecture/backend",
              "get-started/architecture/infrastructure",
              "get-started/architecture/ci-cd"
            ]
          },
          {
            "group": "DEVELOPMENT",
            "pages": [
              "development/local-development",
              "development/testing-strategy",
              "development/local-sql-validation",
              "contributors/overview",
              "contributors/workflow",
              "contributors/code-style"
            ]
          },
          {
            "group": "IMPLEMENTATION REFERENCE",
            "pages": [
              {
                "group": "Backend",
                "icon": "server",
                "expanded": true,
                "pages": [
                  "backend/architecture",
                  {
                    "group": "Operations",
                    "icon": "workflow",
                    "pages": [
                      "backend/ops/cicd"
                    ]
