                    "expanded": false,
                    "pages": [
                      "backend/identity/auth-flow",
                      "backend/identity/contracts",
                      "backend/identity/data-persistence",
                      "backend/identity/api-endpoints"
                    ]
                  },
                  {
                    "group": "Repertoire context",
                    "icon": "music",
                    "pages": [
                      "backend/repertoire"
                    ]
                  }
                ]
              }
            ]
          },
          {
            "group": "AI DEVELOPMENT",
            "pages": [
              "ai-development/overview",
              "ai-development/claude-code",
              "ai-development/skills",
              "ai-development/mcp-servers"
            ]
          }
        ]
      },
