meta {
  name: Register repertoire
  type: http
  seq: 6
}

post {
  url: {{baseUrl}}/api/v1/repertoire
  body: json
  auth: none
}

headers {
  X-User-Id: {{userId}}
  Content-Type: application/json
}

body:json {
  {
    "song_title": "Black",
    "song_artist": "Pearl Jam",
    "instrument": "guitar",
    "proficiency": 8
  }
}

docs {
  Expect 201 Created on first call; 409 Conflict on exact repeat.
}
