{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://campfire.dev/schemas/deployment-record.json",
  "title": "DeploymentRecord",
  "description": "Append-only audit entry for one deployment of one artifact to one environment.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "environment",
    "artifact_key",
    "artifact_version",
    "source_commit",
    "deployed_at",
    "actor",
    "workflow_run_url",
    "outcome",
    "smoke_result",
    "terraform_plan_sha256"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[0-9]{8}T[0-9]{6}Z-[0-9a-f]{7,40}$",
      "description": "<UTC timestamp>-<short commit sha>"
    },
    "environment": {
      "type": "string",
      "enum": ["dev", "prod"]
    },
    "artifact_key": {
      "type": "string",
      "minLength": 1
    },
    "artifact_version": {
      "type": "string",
      "pattern": "^[0-9]{4}\\.[0-9]{2}\\.[0-9]{2}-[0-9a-f]{7,40}$"
    },
    "source_commit": {
      "type": "string",
      "pattern": "^[0-9a-f]{40}$"
    },
    "deployed_at": {
      "type": "string",
      "format": "date-time"
    },
    "actor": {
      "type": "string",
      "minLength": 1,
      "description": "GitHub login that triggered the deploy."
    },
    "approved_by": {
      "type": ["string", "null"],
      "description": "Required (non-null) when environment requires approval."
    },
    "approved_at": {
      "type": ["string", "null"],
      "format": "date-time"
    },
    "workflow_run_url": {
      "type": "string",
      "format": "uri"
    },
    "outcome": {
      "type": "string",
      "enum": ["succeeded", "failed", "rolled-back"]
    },
    "previous_artifact_key": {
      "type": ["string", "null"],
      "description": "The artifact this replaced; used as the rollback target."
    },
    "rollback_of": {
      "type": ["string", "null"],
      "description": "If this record is a rollback, the id of the failed deployment it rolls back."
    },
    "smoke_result": {
      "type": "string",
      "enum": ["pass", "fail", "skipped"]
    },
    "terraform_plan_sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$",
      "description": "Hash of the plan file that was applied (no re-planning between approval and apply)."
    }
  },
  "allOf": [
    {
      "if": { "properties": { "environment": { "const": "prod" } } },
      "then": {
        "required": ["approved_by", "approved_at"],
        "properties": {
          "approved_by": { "type": "string" },
          "approved_at": { "type": "string", "format": "date-time" }
        }
      }
    }
  ]
}
