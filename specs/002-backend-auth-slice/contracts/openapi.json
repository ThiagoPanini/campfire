{
  "openapi": "3.1.0",
  "info": {
    "title": "Campfire API — Identity Slice",
    "version": "0.1.0-draft",
    "description": "Initial draft of the Campfire backend identity-slice contract. The authoritative contract is the OpenAPI document generated by the running FastAPI app; this file is regenerated by `make openapi-snapshot` and committed alongside code changes. Endpoints out of scope (songs, groups, jam sessions, real Google OAuth) are deliberately absent.",
    "contact": {
      "name": "Campfire maintainers",
      "url": "https://github.com/ThiagoPanini/campfire"
    }
  },
  "servers": [
    {
      "url": "http://localhost:8000",
      "description": "Local dev (uvicorn --reload)"
    }
  ],
  "tags": [
    { "name": "auth", "description": "Authentication and session lifecycle." },
    { "name": "me", "description": "Authenticated caller's own profile and preferences." },
    { "name": "ops", "description": "Operational endpoints (no user data)." }
  ],
  "paths": {
    "/auth/register": {
      "post": {
        "tags": ["auth"],
        "summary": "Register a new user with email and password.",
        "operationId": "register_user",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/RegisterRequest" }
            }
          }
        },
        "responses": {
          "201": {
            "description": "User created; access token in body, refresh-token cookie set.",
            "headers": {
              "Set-Cookie": { "$ref": "#/components/headers/RefreshCookie" }
            },
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/TokenResponse" }
              }
            }
          },
          "409": {
            "description": "Email already registered (generic conflict; see FR-002, FR-011).",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          },
          "422": { "$ref": "#/components/responses/ValidationError" },
          "429": { "$ref": "#/components/responses/RateLimited" }
        }
      }
    },
    "/auth/login": {
      "post": {
        "tags": ["auth"],
        "summary": "Authenticate with email and password.",
        "operationId": "login",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/LoginRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Authentication successful; access token in body, refresh-token cookie set.",
            "headers": {
              "Set-Cookie": { "$ref": "#/components/headers/RefreshCookie" }
            },
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/TokenResponse" }
              }
            }
          },
          "401": { "$ref": "#/components/responses/AuthFailure" },
          "422": { "$ref": "#/components/responses/ValidationError" },
          "429": { "$ref": "#/components/responses/RateLimited" }
        }
      }
    },
    "/auth/refresh": {
      "post": {
        "tags": ["auth"],
        "summary": "Exchange the refresh-token cookie for a new access token (rotates the cookie).",
        "description": "Single-use rotation. Reusing a consumed refresh token revokes the entire session family. Protected against CSRF: requires the current access token in the `Authorization` header in addition to the refresh-token cookie (FR-008a).",
        "operationId": "refresh_session",
        "security": [{ "BearerAuth": [] }],
        "responses": {
          "200": {
            "description": "Refreshed; new access token in body, new refresh-token cookie set.",
            "headers": {
              "Set-Cookie": { "$ref": "#/components/headers/RefreshCookie" }
            },
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/TokenResponse" }
              }
            }
          },
          "401": { "$ref": "#/components/responses/AuthFailure" }
        }
      }
    },
    "/auth/sign-out": {
      "post": {
        "tags": ["auth"],
        "summary": "Revoke the current session and clear the refresh-token cookie.",
        "operationId": "sign_out",
        "security": [{ "BearerAuth": [] }],
        "responses": {
          "204": {
            "description": "Signed out; refresh-token cookie cleared (Max-Age=0).",
            "headers": {
              "Set-Cookie": { "$ref": "#/components/headers/RefreshCookieCleared" }
            }
          },
          "401": { "$ref": "#/components/responses/AuthFailure" }
        }
      }
    },
    "/auth/google-stub": {
      "post": {
        "tags": ["auth"],
        "summary": "Dev-only Google identity stub. Disabled by default in production.",
        "description": "Mints a session for either the seeded user (intent=sign-in) or the managed-google fixture user (intent=sign-up). No real OAuth handshake.",
        "operationId": "google_stub_sign_in",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/GoogleStubRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Stub session minted.",
            "headers": {
              "Set-Cookie": { "$ref": "#/components/headers/RefreshCookie" }
            },
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/TokenResponse" }
              }
            }
          },
          "404": {
            "description": "Stub disabled in this environment (FR-018).",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          },
          "422": { "$ref": "#/components/responses/ValidationError" }
        }
      }
    },
    "/me": {
      "get": {
        "tags": ["me"],
        "summary": "Return the authenticated user's profile and preferences.",
        "operationId": "get_me",
        "security": [{ "BearerAuth": [] }],
        "responses": {
          "200": {
            "description": "Profile and preferences for the authenticated caller.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Me" }
              }
            }
          },
          "401": { "$ref": "#/components/responses/AuthFailure" }
        }
      }
    },
    "/me/preferences": {
      "patch": {
        "tags": ["me"],
        "summary": "Replace the authenticated user's preferences (full replacement, not merge).",
        "operationId": "update_preferences",
        "security": [{ "BearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/Preferences" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Preferences replaced.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Me" }
              }
            }
          },
          "401": { "$ref": "#/components/responses/AuthFailure" },
          "422": { "$ref": "#/components/responses/ValidationError" }
        }
      }
    },
    "/health": {
      "get": {
        "tags": ["ops"],
        "summary": "Liveness probe. No auth, no user data, no version info.",
        "operationId": "health",
        "responses": {
          "200": {
            "description": "Process is up.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": { "status": { "const": "ok" } },
                  "required": ["status"]
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "BearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "description": "Opaque server-issued access token (NOT a JWT). Treat as an opaque string."
      }
    },
    "headers": {
      "RefreshCookie": {
        "description": "Sets the refresh-token cookie. `HttpOnly; Secure; SameSite=Lax; Path=/auth/refresh`.",
        "schema": { "type": "string" },
        "example": "campfire_refresh=<opaque>; Path=/auth/refresh; HttpOnly; Secure; SameSite=Lax; Max-Age=1209600"
      },
      "RefreshCookieCleared": {
        "description": "Clears the refresh-token cookie.",
        "schema": { "type": "string" },
        "example": "campfire_refresh=; Path=/auth/refresh; HttpOnly; Secure; SameSite=Lax; Max-Age=0"
      }
    },
    "responses": {
      "AuthFailure": {
        "description": "Generic authentication failure. Does not disclose whether the email exists, the password was wrong, or the token was expired vs. revoked (FR-011).",
        "content": {
          "application/json": { "schema": { "$ref": "#/components/schemas/Error" } }
        }
      },
      "ValidationError": {
        "description": "Request body failed validation.",
        "content": {
          "application/json": { "schema": { "$ref": "#/components/schemas/ValidationError" } }
        }
      },
      "RateLimited": {
        "description": "Rate limit exceeded for (client IP, target email).",
        "headers": {
          "Retry-After": {
            "schema": { "type": "integer", "minimum": 1 },
            "description": "Seconds the caller should wait before retrying."
          }
        },
        "content": {
          "application/json": { "schema": { "$ref": "#/components/schemas/Error" } }
        }
      }
    },
    "schemas": {
      "RegisterRequest": {
        "type": "object",
        "required": ["email", "password"],
        "properties": {
          "email": { "type": "string", "format": "email", "maxLength": 320 },
          "password": { "type": "string", "minLength": 8, "writeOnly": true }
        }
      },
      "LoginRequest": {
        "type": "object",
        "required": ["email", "password"],
        "properties": {
          "email": { "type": "string", "format": "email", "maxLength": 320 },
          "password": { "type": "string", "writeOnly": true }
        }
      },
      "GoogleStubRequest": {
        "type": "object",
        "required": ["intent"],
        "properties": {
          "intent": {
            "type": "string",
            "enum": ["sign-in", "sign-up"]
          }
        }
      },
      "TokenResponse": {
        "type": "object",
        "required": ["accessToken", "tokenType", "expiresIn"],
        "properties": {
          "accessToken": {
            "type": "string",
            "description": "Opaque bearer token. Do not decode."
          },
          "tokenType": { "const": "Bearer" },
          "expiresIn": {
            "type": "integer",
            "minimum": 1,
            "description": "Access-token lifetime in seconds, relative to receipt time."
          }
        }
      },
      "Me": {
        "type": "object",
        "required": ["displayName", "email", "firstLogin", "preferences"],
        "properties": {
          "displayName": { "type": "string", "minLength": 1, "maxLength": 80 },
          "email": { "type": "string", "format": "email" },
          "firstLogin": { "type": "boolean" },
          "preferences": { "$ref": "#/components/schemas/Preferences" }
        }
      },
      "Preferences": {
        "type": "object",
        "required": ["instruments", "genres", "context", "goals", "experience"],
        "properties": {
          "instruments": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/InstrumentId" },
            "uniqueItems": true
          },
          "genres": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/GenreId" },
            "uniqueItems": true
          },
          "context": {
            "anyOf": [
              { "$ref": "#/components/schemas/ContextId" },
              { "type": "null" }
            ]
          },
          "goals": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/GoalId" },
            "uniqueItems": true
          },
          "experience": {
            "anyOf": [
              { "$ref": "#/components/schemas/ExperienceLevel" },
              { "type": "null" }
            ]
          }
        }
      },
      "InstrumentId": {
        "type": "string",
        "enum": [
          "Guitar", "Bass", "Drums", "Piano / Keys", "Vocals",
          "Violin", "Cavaquinho", "Ukulele", "Cajón", "Mandolin",
          "Flute", "Other"
        ]
      },
      "GenreId": {
        "type": "string",
        "enum": [
          "Rock", "MPB", "Samba", "Jazz", "Forró", "Bossa Nova",
          "Pop", "Blues", "Country", "Metal", "Reggae", "Funk", "Other"
        ]
      },
      "ContextId": {
        "type": "string",
        "enum": [
          "Roda de amigos",
          "Banda amadora",
          "Banda profissional",
          "Prática solo",
          "Grupo de louvor",
          "Sessões / Jam sessions"
        ]
      },
      "GoalId": {
        "type": "string",
        "enum": [
          "Learn new songs faster",
          "Track my full repertoire",
          "Share my set with the group",
          "Prepare for jam sessions",
          "Practice more consistently",
          "Know what I can already play"
        ]
      },
      "ExperienceLevel": {
        "type": "string",
        "enum": ["beginner", "learning", "intermediate", "advanced"]
      },
      "Error": {
        "type": "object",
        "required": ["code", "message"],
        "properties": {
          "code": { "type": "string", "description": "Stable machine-readable error code." },
          "message": { "type": "string", "description": "Human-readable, locale-agnostic." }
        }
      },
      "ValidationError": {
        "type": "object",
        "required": ["code", "message", "details"],
        "properties": {
          "code": { "const": "validation_error" },
          "message": { "type": "string" },
          "details": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["loc", "msg", "type"],
              "properties": {
                "loc": { "type": "array", "items": { "type": ["string", "integer"] } },
                "msg": { "type": "string" },
                "type": { "type": "string" }
              }
            }
          }
        }
      }
    }
  }
}
