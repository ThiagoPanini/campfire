APP_NAME=campfire-api
APP_ENV=local
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=campfire-local
AWS_SECRET_ACCESS_KEY=campfire-local
AWS_SESSION_TOKEN=campfire-local
AWS_EC2_METADATA_DISABLED=true
DYNAMODB_ENDPOINT_URL=http://localhost:4566
LOCAL_USERS_TABLE=campfire-local-users
WEB_BASE_URL=http://localhost:5173
API_BASE_URL=http://localhost:8010
USER_POOL_ID=local-user-pool
USER_POOL_CLIENT_ID=campfire-web
USER_POOL_DOMAIN=localhost
LOCAL_API_HOST=127.0.0.1
LOCAL_API_PORT=8010
LOCAL_API_ALLOW_ORIGIN=*
LOCAL_AUTH_ISSUER=http://localhost:8010
LOCAL_AUTH_AUDIENCE=campfire-web
LOCAL_AUTH_KID=campfire-local-dev
