DATABASE_URL=postgresql+asyncpg://campfire:campfire@localhost:5432/campfire
ACCESS_TOKEN_TTL_SECONDS=900
REFRESH_TOKEN_TTL_SECONDS=1209600
CORS_ORIGINS=http://localhost:5173
GOOGLE_STUB_ENABLED=true
RATE_LIMIT_PER_WINDOW=10
RATE_LIMIT_WINDOW_SECONDS=300
LOG_LEVEL=INFO
ENV=dev
REFRESH_COOKIE_NAME=campfire_refresh
REFRESH_COOKIE_DOMAIN=

# Repertoire slice — Deezer catalog + search cache + rate limiter
DEEZER_BASE_URL=https://api.deezer.com
SEARCH_CACHE_TTL_SECONDS=60
SEARCH_CACHE_MAX_ENTRIES=1024
SEARCH_RATE_LIMIT_PER_WINDOW=30
SEARCH_RATE_LIMIT_WINDOW_SECONDS=60

# Render production example:
# DATABASE_URL=postgresql://<user>:<password>@<host>:5432/<database>
# PYTHON_VERSION=3.12.3
# ENV=prod
# CORS_ORIGINS=https://campfire-web.onrender.com
# GOOGLE_STUB_ENABLED=false
